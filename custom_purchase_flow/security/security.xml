<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="group_purchase_coordinator" model="res.groups">
            <field name="name">Coordinator</field>
            <field name="comment">Can create drafts and submit for approval</field>
            <field name="category_id" ref="base.module_category_inventory_purchase"/>
            <field name="implied_ids" eval="[(4, ref('purchase.group_purchase_user'))]"/>
        </record>

        <record id="group_purchase_direction" model="res.groups">
            <field name="name">Direction</field>
            <field name="comment">Can approve or reject purchase orders</field>
            <field name="category_id" ref="base.module_category_inventory_purchase"/>
            <field name="implied_ids" eval="[(4, ref('purchase.group_purchase_manager'))]"/>
        </record>

        <record id="group_purchase_dept" model="res.groups">
            <field name="name">Purchase Department</field>
            <field name="comment">Can send to vendor, manage fulfilling/transit states</field>
            <field name="category_id" ref="base.module_category_inventory_purchase"/>
            <field name="implied_ids" eval="[(4, ref('purchase.group_purchase_user'))]"/>
        </record>

        <record id="group_purchase_cashier" model="res.groups">
            <field name="name">Cashier</field>
            <field name="comment">Can confirm physical arrival</field>
            <field name="category_id" ref="base.module_category_inventory_purchase"/>
            <field name="implied_ids" eval="[(4, ref('purchase.group_purchase_user'))]"/>
        </record>

    </data>
</odoo>
