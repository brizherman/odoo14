<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Purchase Order PDF: internal reference column (same source as form "Ref.") -->
    <template id="report_purchaseorder_document_item_column" inherit_id="purchase.report_purchaseorder_document">
        <xpath expr="//th[@name='th_description']" position="before">
            <th name="th_item" class="text-left"><strong>Item</strong></th>
        </xpath>
        <xpath expr="//tbody//td[@id='product']" position="before">
            <td name="td_item">
                <span t-field="line.product_default_code"/>
            </td>
        </xpath>
    </template>
</odoo>
