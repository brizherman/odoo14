<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_purchase_order_reject_wizard_form" model="ir.ui.view">
            <field name="name">purchase.order.reject.wizard.form</field>
            <field name="model">purchase.order.reject.wizard</field>
            <field name="arch" type="xml">
                <form string="Reject Purchase Order">
                    <sheet>
                        <group>
                            <field name="purchase_order_id" readonly="1"/>
                            <field name="rejection_reason" placeholder="Enter rejection reason..."/>
                        </group>
                    </sheet>
                    <footer>
                        <button name="action_reject_to_draft"
                                type="object"
                                string="Reject → Return to Draft"
                                class="oe_highlight"/>
                        <button name="action_reject_to_cancel"
                                type="object"
                                string="Reject → Cancel"
                                class="btn-secondary"/>
                        <button special="cancel"
                                string="Discard"
                                class="btn-secondary"/>
                    </footer>
                </form>
            </field>
        </record>

    </data>
</odoo>
